{
  "name": "notify-on-done",
  "description": "Windows toast notification with project name when Claude Code finishes responding",
  "version": "1.0.2",
  "author": {
    "name": "rarebek",
    "url": "https://github.com/rarebek"
  },
  "homepage": "https://github.com/rarebek/claude-marketplace",
  "repository": "https://github.com/rarebek/claude-marketplace",
  "license": "MIT",
  "keywords": ["notification", "windows", "toast"],
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "shell": "powershell",
            "command": "$project = Split-Path -Leaf (Get-Location); New-BurntToastNotification -Text \"Claude Code - $project\", 'Done' -Sound 'IM' -UniqueIdentifier 'claude-code'",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
